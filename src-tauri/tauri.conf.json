{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Linknome",
  "version": "0.1.4",
  "identifier": "com.pragmile.linknome",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Linknome",
        "width": 340,
        "height": 220,
        "minWidth": 300,
        "minHeight": 112,
        "maxWidth": 640,
        "maxHeight": 480,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "center": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 Pragmile. Licensed under GPL-2.0-or-later.",
    "category": "Music",
    "shortDescription": "Ableton Link tempo & meter remote",
    "longDescription": "Small always-on-top remote for controlling the tempo and meter (beats-per-bar / Link quantum) of an Ableton Link session over WiFi."
  }
}
